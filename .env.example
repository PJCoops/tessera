# Daily social post — copy to .env and fill in. Never commit secrets.

# Optional override; defaults to https://tesserapuzzle.com/
PUZZLE_URL=https://tesserapuzzle.com/

# X (Twitter) — OAuth 1.0a user context
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Reddit — "script" app owned by u/coopstar230
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=coopstar230
REDDIT_PASSWORD=

# Facebook Page (Graph API)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# Bluesky — handle + App Password (Settings → Privacy and security → App Passwords)
BSKY_HANDLE=
BSKY_APP_PASSWORD=

# Flags
DRY_RUN=0
# ONLY=x,reddit,facebook
